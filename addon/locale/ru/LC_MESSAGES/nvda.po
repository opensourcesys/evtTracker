#. Translators: input help message for a command in Event Tracker add-on.
#: addon/globalPlugins/evtTracker.py:226
msgid "Shows the list of processed events"
msgstr "Показывает список обработанных событий"

#. Translators: title of a dialog displaying recent events.
#: addon/globalPlugins/evtTracker.py:249
msgid "Events List"
msgstr "Список Событий"

#. Translators: label for a read-only edit field displaying event properties.
#: addon/globalPlugins/evtTracker.py:265
msgid "Event &description"
msgstr "&Описание события"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "Event Tracker"
msgstr "Отслеживание Событий"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "Tracks events and displays information about them"
msgstr "Отслеживает события и отображает информацию о них"

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* The events list dialog will no longer show confusing information for the last event description when left open for an extended time.\n"
"* UIA drop target effect text is fetched from the focus ancestor object if the UIA object raising this event does not record this information."
msgstr "* В диалоге списка событий больше не будет отображаться запутанная информация для описания последнего события, если оно остаётся открытым в течение длительного времени.\n"
"* Текст эффекта удаления цели UIA извлекается из объекта-предка фокуса, если объект UIA, вызывающий это событие, не записывает эту информацию."

